{
  "theme": "tokyo-night",
  "display": {
    "colorCompatibility": "truecolor",
    "autoWrap": false,
    "style": "tui",
    "charset": "unicode",
    "tui": {
      "fitContent": true,
      "padding": { "horizontal": 4 },
      "separator": { "column": "  " },
      "title": {
        "right": "{dir}"
      },
      "footer": {
        "right": "{metrics.lastResponseIcon} {metrics.lastResponseVal}"
      },
      "breakpoints": [
        {
          "minWidth": 80,
          "areas": [
            "git.head     git.head     git.head     .               weekly",
            "---",
            "context.icon  context.bar  context.bar  context.pct     context.tokens",
            "block.icon    block.bar    block.bar    block.value     block.time"
          ],
          "columns": ["auto", "1fr", "auto", "auto", "auto"],
          "align": ["left", "left", "right", "right", "right"]
        },
        {
          "minWidth": 55,
          "areas": [
            "git.head             weekly",
            "---",
            "context.bar          context.tokens",
            "block                ."
          ],
          "columns": ["1fr", "auto"],
          "align": ["left", "right"]
        },
        {
          "minWidth": 0,
          "areas": [
            "git.head",
            "weekly",
            "---",
            "context",
            "block"
          ],
          "columns": ["1fr"],
          "align": ["left"]
        }
      ]
    },
    "lines": [
      {
        "segments": {
          "directory": {
            "enabled": true,
            "showBasename": true
          },
          "git": {
            "enabled": true,
            "showSha": false,
            "showAheadBehind": true,
            "showWorkingTree": false,
            "showOperation": true,
            "showTag": false,
            "showTimeSinceCommit": false,
            "showStashCount": false,
            "showUpstream": false,
            "showRepoName": false
          },
          "model": {
            "enabled": true
          },
          "block": {
            "enabled": true,
            "type": "tokens"
          },
          "session": {
            "enabled": false,
            "type": "tokens",
            "burnType": "none"
          },
          "today": {
            "enabled": false,
            "type": "tokens"
          },
          "context": {
            "enabled": true,
            "showPercentageOnly": false,
            "autocompactBuffer": 0
          },
          "tmux": {
            "enabled": false
          },
          "metrics": {
            "enabled": true,
            "showLastResponseTime": true,
            "showResponseTime": false,
            "showDuration": false,
            "showMessageCount": false,
            "showLinesAdded": false,
            "showLinesRemoved": false
          },
          "version": {
            "enabled": false
          }
        }
      }
    ]
  },
  "colors": {
    "custom": {
      "metrics.lastResponseIcon": { "fg": "#bb9af7" },
      "metrics.lastResponseVal": { "fg": "#9d7cd8" }
    }
  },
  "budget": {
    "session": {
      "warningThreshold": 80
    },
    "today": {
      "amount": 5.0,
      "warningThreshold": 80
    },
    "block": {
      "amount": 20000000,
      "type": "tokens",
      "warningThreshold": 80
    }
  }
}
