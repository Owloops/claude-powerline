{
  "display": {
    "colorCompatibility": "truecolor",
    "autoWrap": false,
    "style": "tui",
    "charset": "unicode",
    "tui": {
      "widthReserve": 100,
      "separator": { "column": "  " },
      "breakpoints": [
        {
          "minWidth": 80,
          "areas": [
            "git       git        git       dir",
            "---",
            "context   context    context   context",
            "block     .          weekly    metrics.lastResponse"
          ],
          "columns": ["1fr", "auto", "auto", "auto"],
          "align": ["left", "left", "right", "right"]
        },
        {
          "minWidth": 55,
          "areas": [
            "git                  dir",
            "---",
            "context              context",
            "block                weekly",
            "metrics.lastResponse ."
          ],
          "columns": ["1fr", "1fr"],
          "align": ["left", "right"]
        },
        {
          "minWidth": 0,
          "areas": [
            "git",
            "dir",
            "---",
            "context",
            "block",
            "weekly",
            "metrics.lastResponse"
          ],
          "columns": ["1fr"],
          "align": ["left"]
        }
      ]
    },
    "lines": [
      {
        "segments": {
          "directory": {
            "enabled": true,
            "showBasename": true
          },
          "git": {
            "enabled": true,
            "showSha": false,
            "showAheadBehind": true,
            "showWorkingTree": false,
            "showOperation": true,
            "showTag": false,
            "showTimeSinceCommit": false,
            "showStashCount": false,
            "showUpstream": false,
            "showRepoName": false
          },
          "model": {
            "enabled": true
          },
          "block": {
            "enabled": true,
            "type": "tokens"
          },
          "session": {
            "enabled": false,
            "type": "tokens",
            "burnType": "none"
          },
          "today": {
            "enabled": false,
            "type": "tokens"
          },
          "context": {
            "enabled": true,
            "showPercentageOnly": false,
            "autocompactBuffer": 0
          },
          "tmux": {
            "enabled": false
          },
          "metrics": {
            "enabled": true,
            "showLastResponseTime": true,
            "showResponseTime": false,
            "showDuration": false,
            "showMessageCount": false,
            "showLinesAdded": false,
            "showLinesRemoved": false
          },
          "version": {
            "enabled": false
          }
        }
      }
    ]
  },
  "budget": {
    "session": {
      "warningThreshold": 80
    },
    "today": {
      "amount": 5.0,
      "warningThreshold": 80
    },
    "block": {
      "amount": 20000000,
      "type": "tokens",
      "warningThreshold": 80
    }
  }
}
